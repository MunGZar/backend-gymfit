# ==========================================
# GymFit Backend - variables de entorno
# ==========================================

# Application
NODE_ENV=development
PORT=3001

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_NAME=gymfit
DB_PASSWORD=CHANGE_ME

# JWT Authentication
# IMPORTANTE: Generar un secreto seguro con: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_A_RANDOM_64_CHAR_SECRET
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRATION=7d

# CORS — Frontend Next.js corre en :3000
CORS_ORIGIN=http://localhost:3000

# Bcrypt
BCRYPT_SALT_ROUNDS=10
